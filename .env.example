# AI 模型配置（必填）
# DeepSeek: https://platform.deepseek.com 获取 API Key
AI_API_KEY=your_deepseek_api_key_here
AI_BASE_URL=https://api.deepseek.com/chat/completions
AI_MODEL=deepseek-chat

# 时区（可选）
TIMEZONE=Asia/Shanghai

# 即梦 AI 生图（Phase 3，可选）
# 火山引擎控制台获取：https://console.volcengine.com
IMAGE_GEN_AK=your_access_key_id
IMAGE_GEN_SK=your_secret_access_key
