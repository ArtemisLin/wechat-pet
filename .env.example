# AI 模型（OpenAI 兼容 API）
AI_API_KEY=your_api_key
AI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
AI_MODEL=ep-xxxxx

# 宠物
BOT_NAME=小企鹅

# 时区
TIMEZONE=Asia/Shanghai

# 宠物参数（可选，有默认值）
# HUNGER_DECAY_RATE=5          # 每次衰减减少的饱腹值
# HUNGER_DECAY_INTERVAL_MIN=30 # 衰减间隔（分钟）
# HUNGER_ALERT_THRESHOLD=20    # 主动喊饿的阈值
# FEED_AMOUNT=30               # 每次喂食增加的饱腹值
